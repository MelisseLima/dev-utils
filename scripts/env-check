#!/usr/bin/env bash
# 🔐 env-check — compare .env.example with .env and flag missing vars
set -euo pipefail

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo ""
echo -e "${CYAN}  🔐  E N V   C H E C K${NC}"
echo ""

PROJECT_DIR="${1:-.}"

# Find the example file
EXAMPLE_FILE=""
for candidate in "$PROJECT_DIR/.env.example" "$PROJECT_DIR/.env.sample" "$PROJECT_DIR/.env.template"; do
  if [[ -f "$candidate" ]]; then
    EXAMPLE_FILE="$candidate"
    break
  fi
done

if [[ -z "$EXAMPLE_FILE" ]]; then
  echo -e "${RED}  ✗ No .env.example, .env.sample, or .env.template found.${NC}"
  exit 1
fi

ENV_FILE="$PROJECT_DIR/.env"

if [[ ! -f "$ENV_FILE" ]]; then
  echo -e "${RED}  ✗ No .env file found!${NC}"
  echo -e "${YELLOW}  Tip: cp $EXAMPLE_FILE $ENV_FILE${NC}"
  exit 1
fi

echo -e "${GREEN}▸ Comparing: $(basename "$EXAMPLE_FILE") → .env${NC}"
echo ""

missing=0
empty=0

# Extract variable names from the example file
while IFS= read -r line; do
  # Skip empty lines and comments
  [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue

  # Get the variable name (everything before the first =)
  var_name=$(echo "$line" | cut -d'=' -f1 | xargs)
  [[ -z "$var_name" ]] && continue

  if ! grep -q "^${var_name}=" "$ENV_FILE" 2>/dev/null; then
    echo -e "${RED}  ✗ MISSING: $var_name${NC}"
    missing=$((missing + 1))
  else
    # Check if value is empty
    value=$(grep "^${var_name}=" "$ENV_FILE" | cut -d'=' -f2-)
    if [[ -z "$value" ]]; then
      echo -e "${YELLOW}  ⚠ EMPTY:   $var_name${NC}"
      empty=$((empty + 1))
    else
      echo -e "${GREEN}  ✓ OK:      $var_name${NC}"
    fi
  fi
done < "$EXAMPLE_FILE"

echo ""
if [[ "$missing" -eq 0 && "$empty" -eq 0 ]]; then
  echo -e "${GREEN}  ✅  All environment variables are set!${NC}"
elif [[ "$missing" -gt 0 ]]; then
  echo -e "${RED}  ⚠ $missing missing variable(s), $empty empty variable(s).${NC}"
else
  echo -e "${YELLOW}  ⚠ $empty empty variable(s), but nothing missing.${NC}"
fi
echo ""

#!/usr/bin/env bash
# 🚀 dev-up — detect project type and start it up
set -euo pipefail

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo ""
echo -e "${CYAN}  🚀  D E V   U P${NC}"
echo ""

PROJECT_DIR="${1:-.}"
cd "$PROJECT_DIR"

step() {
  echo -e "${GREEN}▸ $1${NC}"
}

warn() {
  echo -e "${YELLOW}  ⚠ $1${NC}"
}

# --- Docker Compose ---
if [[ -f "docker-compose.yml" || -f "docker-compose.yaml" || -f "compose.yml" || -f "compose.yaml" ]]; then
  step "Docker Compose detected"
  compose_file=$(ls docker-compose.yml docker-compose.yaml compose.yml compose.yaml 2>/dev/null | head -1)
  step "Running: docker compose up -d"
  docker compose -f "$compose_file" up -d 2>/dev/null || docker-compose -f "$compose_file" up -d
fi

# --- Node.js (package.json) ---
if [[ -f "package.json" ]]; then
  step "Node.js project detected"

  # Determine package manager
  if [[ -f "pnpm-lock.yaml" ]]; then
    PM="pnpm"
  elif [[ -f "yarn.lock" ]]; then
    PM="yarn"
  elif [[ -f "bun.lockb" || -f "bun.lock" ]]; then
    PM="bun"
  else
    PM="npm"
  fi

  step "Package manager: $PM"

  # Install dependencies if node_modules doesn't exist
  if [[ ! -d "node_modules" ]]; then
    step "Installing dependencies..."
    $PM install
  else
    warn "node_modules exists — skipping install"
  fi

  # Detect start script
  if grep -q '"dev"' package.json 2>/dev/null; then
    step "Running: $PM run dev"
    $PM run dev
  elif grep -q '"start"' package.json 2>/dev/null; then
    step "Running: $PM start"
    $PM start
  else
    warn "No 'dev' or 'start' script found in package.json"
  fi

# --- Python (requirements.txt / pyproject.toml / Pipfile) ---
elif [[ -f "requirements.txt" || -f "pyproject.toml" || -f "Pipfile" ]]; then
  step "Python project detected"

  if [[ -f "Pipfile" ]]; then
    step "Running: pipenv install && pipenv run start"
    pipenv install
    pipenv run python main.py 2>/dev/null || pipenv run python app.py 2>/dev/null || warn "Could not find entry point (main.py or app.py)"

  elif [[ -f "pyproject.toml" ]]; then
    if grep -q "poetry" pyproject.toml 2>/dev/null; then
      step "Poetry project detected"
      poetry install
      poetry run python main.py 2>/dev/null || poetry run python app.py 2>/dev/null || warn "Could not find entry point"
    else
      step "Running: pip install -e ."
      pip install -e .
    fi

  elif [[ -f "requirements.txt" ]]; then
    # Create venv if it doesn't exist
    if [[ ! -d ".venv" && ! -d "venv" ]]; then
      step "Creating virtual environment..."
      python3 -m venv .venv
    fi

    venv_dir=$([[ -d ".venv" ]] && echo ".venv" || echo "venv")
    step "Activating virtualenv and installing requirements..."
    source "$venv_dir/bin/activate"
    pip install -r requirements.txt --quiet

    if [[ -f "manage.py" ]]; then
      step "Django detected — running: python manage.py runserver"
      python manage.py runserver
    elif [[ -f "app.py" ]]; then
      step "Running: python app.py"
      python app.py
    elif [[ -f "main.py" ]]; then
      step "Running: python main.py"
      python main.py
    else
      warn "Could not detect entry point."
    fi
  fi

# --- Go ---
elif [[ -f "go.mod" ]]; then
  step "Go project detected"
  step "Running: go run ."
  go run .

# --- Rust ---
elif [[ -f "Cargo.toml" ]]; then
  step "Rust project detected"
  step "Running: cargo run"
  cargo run

# --- Nothing found ---
else
  echo -e "${RED}  ✗ Could not detect project type.${NC}"
  echo -e "${YELLOW}    Supported: Node.js, Python, Go, Rust, Docker Compose${NC}"
  exit 1
fi

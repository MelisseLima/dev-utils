#!/usr/bin/env bash
# ☕ good-morning — wake up fresh: stop everything Docker and scrub it clean
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

banner() {
  echo ""
  echo -e "${CYAN}  ☀️  G O O D   M O R N I N G  ☀️${NC}"
  echo -e "${YELLOW}  Time to kick Docker out of bed.${NC}"
  echo ""
}

step() {
  echo -e "${GREEN}▸ $1${NC}"
}

warn() {
  echo -e "${YELLOW}  ⚠ $1${NC}"
}

banner

# --- Stop all running containers ---
running=$(docker ps -q 2>/dev/null || true)
if [[ -n "$running" ]]; then
  step "Stopping all running containers..."
  docker stop $running
else
  warn "No running containers — already sleeping."
fi

# --- Remove all containers (stopped included) ---
all_containers=$(docker ps -aq 2>/dev/null || true)
if [[ -n "$all_containers" ]]; then
  step "Removing all containers..."
  docker rm -f $all_containers
else
  warn "No containers to remove."
fi

# --- Remove all images ---
all_images=$(docker images -q 2>/dev/null || true)
if [[ -n "$all_images" ]]; then
  step "Removing all images..."
  docker rmi -f $all_images
else
  warn "No images to remove."
fi

# --- Remove all volumes ---
all_volumes=$(docker volume ls -q 2>/dev/null || true)
if [[ -n "$all_volumes" ]]; then
  step "Removing all volumes..."
  docker volume rm -f $all_volumes
else
  warn "No volumes to remove."
fi

# --- Remove all networks (except defaults) ---
custom_networks=$(docker network ls --filter type=custom -q 2>/dev/null || true)
if [[ -n "$custom_networks" ]]; then
  step "Removing custom networks..."
  docker network rm $custom_networks 2>/dev/null || true
else
  warn "No custom networks to remove."
fi

# --- Final prune for good measure ---
step "Running system prune for anything left behind..."
docker system prune -af --volumes 2>/dev/null || true

echo ""
echo -e "${CYAN}  ✅  All clean! Docker is fresh like a new day.${NC}"
echo -e "${CYAN}  ☕  Now go grab some coffee.${NC}"
echo ""

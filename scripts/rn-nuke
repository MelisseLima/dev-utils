#!/usr/bin/env bash
# ☢️ rn-nuke — nuclear clean for React Native projects
set -euo pipefail

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo ""
echo -e "${CYAN}  ☢️  R N   N U K E${NC}"
echo -e "${YELLOW}  Going nuclear on caches and build artifacts...${NC}"
echo ""

step() { echo -e "${GREEN}▸ $1${NC}"; }
warn() { echo -e "${YELLOW}  ⚠ $1${NC}"; }

# --- Kill Metro bundler if running ---
metro_pids=$(pgrep -f "react-native.*start\|metro" 2>/dev/null || true)
if [[ -n "$metro_pids" ]]; then
  step "Killing Metro bundler..."
  echo "$metro_pids" | xargs kill -9 2>/dev/null || true
else
  warn "Metro not running."
fi

# --- Clear Watchman ---
if command -v watchman &>/dev/null; then
  step "Clearing Watchman watches..."
  watchman watch-del-all 2>/dev/null || true
else
  warn "Watchman not installed — skipping."
fi

# --- Remove node_modules ---
if [[ -d "node_modules" ]]; then
  step "Removing node_modules..."
  rm -rf node_modules
else
  warn "No node_modules found."
fi

# --- Remove lock file caches ---
step "Clearing package manager caches..."
if [[ -f "yarn.lock" ]]; then
  yarn cache clean 2>/dev/null || true
elif [[ -f "pnpm-lock.yaml" ]]; then
  pnpm store prune 2>/dev/null || true
else
  npm cache clean --force 2>/dev/null || true
fi

# --- iOS cleanup ---
if [[ -d "ios" ]]; then
  step "Cleaning iOS..."
  rm -rf ios/Pods ios/Podfile.lock ios/build ios/.xcode.env.local 2>/dev/null || true
  rm -rf ~/Library/Developer/Xcode/DerivedData 2>/dev/null || true
  step "  Removed Pods, Podfile.lock, ios/build, DerivedData"
else
  warn "No ios/ directory — skipping iOS cleanup."
fi

# --- Android cleanup ---
if [[ -d "android" ]]; then
  step "Cleaning Android..."
  rm -rf android/build android/app/build android/.gradle 2>/dev/null || true
  step "  Removed android/build, android/app/build, .gradle"
else
  warn "No android/ directory — skipping Android cleanup."
fi

# --- Clear Metro / React Native temp caches ---
step "Clearing Metro & temp caches..."
rm -rf "$TMPDIR/react-"* "$TMPDIR/metro-"* "$TMPDIR/haste-"* 2>/dev/null || true
rm -rf .metro-health-check-* 2>/dev/null || true

echo ""
echo -e "${CYAN}  ✅  Nuclear clean complete! Fresh as new. ☢️${NC}"
echo -e "${YELLOW}  Run your package manager install + rn-pod to set up again.${NC}"
echo ""

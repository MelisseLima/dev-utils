#!/usr/bin/env bash
# 🍫 rn-pod — install CocoaPods with repo update and timing
set -euo pipefail

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo ""
echo -e "${CYAN}  🍫  R N   P O D${NC}"
echo -e "${YELLOW}  Installing CocoaPods...${NC}"
echo ""

step() { echo -e "${GREEN}▸ $1${NC}"; }

# --- Check we're in an RN project ---
if [[ ! -d "ios" ]]; then
  echo -e "${RED}  ✗ No ios/ directory found. Are you in a React Native project?${NC}"
  exit 1
fi

if [[ ! -f "ios/Podfile" ]]; then
  echo -e "${RED}  ✗ No Podfile found in ios/.${NC}"
  exit 1
fi

# --- Handle --clean flag ---
if [[ "${1:-}" == "--clean" ]]; then
  step "Removing Pods and Podfile.lock..."
  rm -rf ios/Pods ios/Podfile.lock 2>/dev/null || true
fi

# --- Install pods ---
START_TIME=$(date +%s)

cd ios

if command -v bundle &>/dev/null && [[ -f "../Gemfile" ]]; then
  step "Using bundler: bundle exec pod install --repo-update"
  bundle exec pod install --repo-update
elif command -v pod &>/dev/null; then
  step "Running: pod install --repo-update"
  pod install --repo-update
else
  echo -e "${RED}  ✗ CocoaPods not found. Install with: gem install cocoapods${NC}"
  exit 1
fi

cd ..

END_TIME=$(date +%s)
ELAPSED=$((END_TIME - START_TIME))

echo ""
echo -e "${CYAN}  ✅  Pods installed in ${ELAPSED}s${NC}"
echo ""

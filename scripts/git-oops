#!/usr/bin/env bash
# 🤦 git-oops — undo the last commit, keep changes staged
set -euo pipefail

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo ""
echo -e "${CYAN}  🤦  G I T   O O P S${NC}"
echo ""

# Check we're in a git repo
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo -e "${RED}  ✗ Not inside a git repository.${NC}"
  exit 1
fi

# Check there's at least one commit
if ! git log -1 &>/dev/null; then
  echo -e "${RED}  ✗ No commits to undo.${NC}"
  exit 1
fi

# Show what we're undoing
last_msg=$(git log -1 --pretty=format:"%h %s")
echo -e "${YELLOW}  Undoing: $last_msg${NC}"

# Soft reset — keeps changes staged
git reset --soft HEAD~1

echo ""
echo -e "${GREEN}  ✓ Last commit undone. Your changes are still staged.${NC}"
echo -e "${GREEN}  ✓ Run 'git status' to see what's ready.${NC}"
echo ""

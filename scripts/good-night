#!/usr/bin/env bash
# 🌙 good-night — restore your dev environment: spin up docker-compose projects
set -euo pipefail

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

banner() {
  echo ""
  echo -e "${CYAN}  🌙  G O O D   N I G H T  🌙${NC}"
  echo -e "${YELLOW}  Tucking your dev environment back in...${NC}"
  echo ""
}

step() {
  echo -e "${GREEN}▸ $1${NC}"
}

warn() {
  echo -e "${YELLOW}  ⚠ $1${NC}"
}

fail() {
  echo -e "${RED}  ✗ $1${NC}"
}

banner

# If paths are passed as arguments, use those; otherwise search current dir
if [[ $# -gt 0 ]]; then
  SEARCH_DIRS=("$@")
else
  SEARCH_DIRS=(".")
fi

found=0
for dir in "${SEARCH_DIRS[@]}"; do
  # Find docker-compose files (compose.yml, docker-compose.yml, etc.)
  while IFS= read -r compose_file; do
    [[ -z "$compose_file" ]] && continue
    compose_dir="$(dirname "$compose_file")"
    step "Starting services in $compose_dir..."

    if docker compose -f "$compose_file" up -d 2>/dev/null; then
      echo -e "${GREEN}    ✓ Up and running${NC}"
    elif docker-compose -f "$compose_file" up -d 2>/dev/null; then
      echo -e "${GREEN}    ✓ Up and running (legacy compose)${NC}"
    else
      fail "Failed to start $compose_file"
    fi
    found=$((found + 1))
  done < <(find "$dir" -maxdepth 3 -name "docker-compose.yml" -o -name "docker-compose.yaml" -o -name "compose.yml" -o -name "compose.yaml" 2>/dev/null)
done

if [[ "$found" -eq 0 ]]; then
  warn "No docker-compose files found. Pass project directories as arguments:"
  echo -e "    ${CYAN}good-night ~/projects/api ~/projects/frontend${NC}"
fi

echo ""
echo -e "${CYAN}  ✅  Environment restored! Sweet dreams. 🛏️${NC}"
echo ""

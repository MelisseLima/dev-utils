#!/usr/bin/env bash
# 🌱 git-fresh — checkout default branch, pull, and create a new branch
set -euo pipefail

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

if [[ $# -eq 0 ]]; then
  echo -e "${YELLOW}Usage: git-fresh <branch-name>${NC}"
  echo -e "  Example: git-fresh feature/add-login"
  echo -e "  Example: git-fresh fix/broken-header"
  exit 1
fi

BRANCH_NAME="$1"

echo ""
echo -e "${CYAN}  🌱  G I T   F R E S H${NC}"
echo ""

# Detect default branch
DEFAULT_BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || echo "")
if [[ -z "$DEFAULT_BRANCH" ]]; then
  if git show-ref --verify --quiet refs/heads/main 2>/dev/null; then
    DEFAULT_BRANCH="main"
  elif git show-ref --verify --quiet refs/heads/master 2>/dev/null; then
    DEFAULT_BRANCH="master"
  else
    echo -e "${RED}  ✗ Could not detect default branch.${NC}"
    exit 1
  fi
fi

echo -e "${GREEN}▸ Switching to $DEFAULT_BRANCH...${NC}"
git checkout "$DEFAULT_BRANCH" --quiet

echo -e "${GREEN}▸ Pulling latest changes...${NC}"
git pull --quiet

echo -e "${GREEN}▸ Creating branch: $BRANCH_NAME${NC}"
git checkout -b "$BRANCH_NAME"

echo ""
echo -e "${CYAN}  ✅  Fresh branch '$BRANCH_NAME' ready to go!${NC}"
echo ""
